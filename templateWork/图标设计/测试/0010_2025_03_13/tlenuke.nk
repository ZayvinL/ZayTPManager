 addUserKnob {22 RondomSize l 更新种子 T "import random\nimport nuke\n\ntn = nuke.thisNode()\n\ntn.begin()\nransize = random.randint(-9999,9999)\nseedsize = tn\[\"seedsize\"].setValue(ransize)\n\ntn\[\"CteatCards\"].execute()\ntn.end()" +STARTLINE}
 addUserKnob {22 CteatCards l 创建随机Card -STARTLINE T "import random\nimport nuke\nimport sqlite3\n# import math\n\ntn = nuke.thisNode()\n\ntn.begin()\n\ndef deselect():\n\tfor i in nuke.allNodes():\n\t\ti.setSelected(False)\ndef clear():\n\tfor i in nuke.allNodes():\n\t\tif i\['name'].getValue() not in \['cam','Output1','TransformGeoAll',\"Scenecc\"]:\n\t\t\tnuke.delete(i)\nclear()\ndeselect()\n\ntransformGeos = nuke.toNode('TransformGeoAll')\nOutput = nuke.toNode('Output1')\ncam = nuke.toNode('cam')\nscj = nuke.toNode(\"Scenecc\")\njdyx = tn\[\"zcheck\"].value()\nimages = tn\[\"ImageInput\"].value()\n\n\n\n\nnum = int(tn\['num'].getValue())\n# col = int(tn\['col'].getValue())\nseedsize = tn\[\"seedsize\"].getValue()\n# 种子\nrandom.seed(seedsize)\n\n#3d空间的范围定位,这里计算采样的最大值和最小值来计算\nposition_3dfrom = tn\[\"position_3dfrom\"].value()\nposition_3dto = tn\[\"position_3dto\"].value()\nposition_3dfd = tn\[\"position_3dfd\"].value()\n\n\nfdx = int(position_3dfd\[0])\nfdy = int(position_3dfd\[1])\nfdz = int(position_3dfd\[2])\n\nxrdfrom = int(position_3dfrom\[0])\nxrdto = int(position_3dto\[0])\n\nyrdfrom = int(position_3dfrom\[1])\nyrdto = int(position_3dto\[1])\n\n\nzrdfrom = int(position_3dfrom\[2])\nzrdto = int(position_3dto\[2])\n\n# 增加一个浮动值\nxrdfrom = xrdfrom + fdx if xrdfrom > 0 else xrdfrom - fdx\nxrdto = xrdto + fdx if xrdto > 0 else xrdto - fdx\n\n\nyrdfrom = yrdfrom + fdy if yrdfrom > 0 else yrdfrom - fdy\nyrdto = yrdto + fdy if yrdto > 0 else yrdto - fdy\n\n\nzrdfrom = zrdfrom + fdz if zrdfrom > 0 else zrdfrom - fdz\nzrdto = zrdto + fdz if zrdto > 0 else zrdto - fdz\n\n\n# 这里找到相机的xy坐标\n\nxps = int(cam\['xpos'].getValue())\nyps = int(cam\['ypos'].getValue())\n\nif not images:\n    checkbd = nuke.createNode(\"CheckerBoard2\",inpanel=False)\n    checkbd.setXYpos(xps+(700),yps+0)\nelse:\n    imgs = \[]\n    for i in range(0,num):\n        img = nuke.createNode(\"Input\",inpanel=False)\n        img.setXYpos(xps+200+(200*i),yps-200)\n        img\[\"label\"].setValue(f\"Input\{i+1\}\")\n        imgs.append(img)\n    \n    texs = \[]\n    for i in range(0,num):\n        tex = nuke.createNode(\"Text2\",inpanel=False)\n        tex\[\"box\"].setExpression(\"0\",0)\n        tex\[\"box\"].setExpression(\"0\",1)\n        tex\[\"box\"].setExpression(\"this.input.width\",2)\n        tex\[\"box\"].setExpression(\"this.input.height\",3)\n        tex\[\"xjustify\"].setValue(1)\n        tex\[\"yjustify\"].setValue(1)\n\n        tex\[\"replace\"].setExpression(\"parent.closeCheckbord\")\n        tex\[\"disable\"].setExpression(\"!parent.ShowInputName\")\n\n        tex\[\"message\"].setValue(f\"Input\{i+1\}\")\n        tex\[\"label\"].setValue(f\"Input\{i+1\}\")\n        tex.setXYpos(xps+200+(200*i),yps-50)\n        tex.setInput(0,imgs\[i])\n        texs.append(tex)\n\n        \n\n# card created\ncards = \[]\ngeos = \[]\n\n# 这里计算一定数量的随机值,在3d空间范围内\nrandom_z = \[random.randint(zrdfrom if zrdfrom < zrdto else zrdto, zrdfrom if zrdfrom > zrdto else zrdto) for _ in range(num)]\nrandom_x = \[random.randint(xrdfrom if xrdfrom < xrdto else xrdto, xrdfrom if xrdfrom > xrdto else xrdto) for _ in range(num)]\nrandom_y = \[random.randint(yrdfrom if yrdfrom < yrdto else yrdto, yrdfrom if yrdfrom > yrdto else yrdto) for _ in range(num)]\n\n\n\n# print(random_x)\n# print(random_y)\n# print(random_z)\n# print(type(random_z))\n\n# 近处大远处小通过这个值来计算\nminz = min(random_z)\n# print(minz)\n\n\n\n\n\n#@------------------------------------\n# 查接近值\n\n\n\n\n\ntarget_values = random_z  \npointspath = tn\[\"pointspath\"].value() + \"PointsSample.db\"\n\ndef fetch_closest_records(db_path, target_values):\n    \"\"\"安全查询每个目标值的最接近记录\"\"\"\n    conn = None\n    try:\n        conn = sqlite3.connect(db_path)\n        cursor = conn.cursor()\n        results = \[]\n        \n        # 逐条查询（避免超长SQL）\n        for value in target_values:\n            # 参数化查询（防SQL注入）\n            cursor.execute(\"\"\"\n                SELECT col1, col2, col3 \n                FROM test_table \n                ORDER BY ABS(col3 - ?) \n                LIMIT 1\n            \"\"\", (value,))\n            result = cursor.fetchone()\n            results.append(result)\n            \n        return results\n        \n    except sqlite3.Error as e:\n        print(f\"数据库错误: \{e\}\")\n        return None\n    finally:\n        if conn:\n            conn.close()\n\n# 执行查询\nresults = fetch_closest_records(pointspath, target_values)\n# print(results)\n# 打印结果\n# if results:\n    # for value, record in zip(target_values, results):\n        # if record:\n            # col1, col2, col3 = record\n            # print(f\"最接近 \{value\} 的记录：col1=\{col1\}, col2=\{col2\}, col3=\{col3\}\")\n        # else:\n            # print(f\"值 \{value\} 无匹配记录\")\n# else:\n    # print(\"查询失败，请检查错误日志\")\n\n\n\nfor i in range(0,num):\n    # i+=1\n\n    card = nuke.createNode(\"Card2\",inpanel=False)\n    card\['selectable'].setValue(False)\n    card\['rows'].setValue(1)\n    card\['columns'].setValue(1)\n    if not images:\n        card.setInput(0,checkbd)\n    else:\n        card.setInput(0,texs\[i])\n        \n    card.setXYpos(xps+(500*i),yps+500)\n    cards.append(card)\n    \n    cpx = int(card\['xpos'].getValue())\n    cpy = int(card\['ypos'].getValue())    \n    \n    trgeo = nuke.createNode(\"TransformGeo\",inpanel=False)\n    \n    if i < len(results) and results\[i] and len(results\[i]) >= 3:\n        retc = list(results\[i])\n\n        fdx = retc\[0]\n        fdy = retc\[1]\n        fdz = retc\[2]\n    else:\n        print(f\"Warning: No valid result found for index \{i\}\")\n        fdx, fdy, fdz = 0, 0, 0  # 设置默认值\n\n    \n\n    rx = random_x\[i]\n    ry = random_y\[i]\n    rz = random_z\[i]\n    # rz = random_z\[i]\n    # print(rx,ry,rz)\n    \n    \n    xexp = f\"parent.translate_3d.x + \{rx\} + \{fdx\} * translate_x\"\n    # print(xexp)\n\n    yexp = f\"parent.translate_3d.y + \{ry\} + \{fdy\} * translate_y\"\n    # print(yexp)\n    \n    zexp = f\"parent.translate_3d.z + \{rz\} + \{fdz\} * translate_z\"\n    \n    \n    # print(zexp)\n    \n    trgeo\['translate'].setExpression(xexp,0)\n    trgeo\['translate'].setExpression(yexp,1)\n    trgeo\['translate'].setExpression(zexp,2)\n    if jdyx:\n        trgeo\['uniform_scale'].setExpression(\"(-this.translate.z * (1/(-this.translate.z/\{\})) * parent.scaleSize)\".format(minz)) #\n    else:\n        trgeo\['uniform_scale'].setExpression(\"-(this.translate.z*parent.scaleSize)\")\n    \n\n    trgeo\['look_rotate_x'].setExpression(\"parent.lookx\")\n    trgeo\['look_rotate_y'].setExpression(\"parent.looky\")\n    trgeo\['look_rotate_z'].setExpression(\"parent.lookz\")\n    \n    trgeo.setInput(0,card)\n    trgeo.setInput(2,cam)\n    trgeo.setInput(1,None)\n    # trgeo.setInput(1,holdf)\n    trgeo.setXYpos(cpx+(0),cpy+300)\n    geos.append(trgeo)\n    \n\ncutsjc = scj.inputs()\nfor i, ged in enumerate(geos):\n    inindex = i+cutsjc\n    scj.setInput(inindex,ged)\n\ntn.end()\n\n\n\n\n\n\n\n\n\n\n\n"}
 addUserKnob {22 ClearExpression l 清除link-拷贝出来单独调整 -STARTLINE T "\nimport nuke\n\n\ntn = nuke.thisNode()\n\nret = nuke.ask(\"清空表达式连接？\")\nif ret:\n    tn.begin()\n\n    for i in nuke.allNodes(\"TransformGeo\"):\n        if i\['name'].getValue() not in \['cam','Output1','TransformGeoAll',\"Scenecc\"]:\n            if i\['translate'].isAnimated():\n                i\['translate'].clearAnimated()\n                \n            if i\['uniform_scale'].isAnimated():\n                i\['uniform_scale'].clearAnimated()\n                \n            for x in \['look_rotate_x','look_rotate_y','look_rotate_z']:\n                if i\[x].isAnimated():\n                    i\[x].clearAnimated()\n    \n    for i in nuke.allNodes(\"FrameHold\"):\n        if i\['firstFrame'].isAnimated():\n            i\['firstFrame'].clearAnimated()\n            \n    for i in nuke.allNodes(\"Text2\"):\n        for x in \['box','replace','yjustify',\"disable\"]:\n            if i\[x].isAnimated():\n                i\[x].clearAnimated()\n                \n\n    tn.end()"}
 addUserKnob {22 matchSamplePoint T "\nimport nuke\n\n\ntn = nuke.thisNode()\n\n\ntn\[\"position_3dfd\"].setValue(\[0,0,0])\ntn\[\"translate_3d\"].setValue(\[0,0,0])\ntn\[\"translate_x\"].setValue(0)\ntn\[\"translate_y\"].setValue(0)\ntn\[\"translate_z\"].setValue(0)" +STARTLINE}
 addUserKnob {26 ""}
 addUserKnob {13 translate_3d l 整体偏移}
 addUserKnob {7 translate_x l "散布 X 间距"}
 addUserKnob {7 translate_y l "散布 Y 间距"}
 addUserKnob {7 translate_z l "散布 Z 间距"}
 addUserKnob {7 scaleSize l 整体缩比例}
 scaleSize 0.218
}
